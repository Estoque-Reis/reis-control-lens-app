rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Master Gate / Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      // In this app, we might not require email verification yet, but it's best practice.
      // For now, let's just check if signed in.
      return isSignedIn();
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function getProfile(userId) {
      return get(/databases/$(database)/documents/profiles/$(userId)).data;
    }

    function isAdmin() {
      return isMasterUser() || (isSignedIn() && exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) && get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role == 'admin');
    }

    function isMasterUser() {
      return isSignedIn() && request.auth.token.email.lower() == 'paulo_ricardo_reis@hotmail.com'.lower();
    }

    // Profiles
    match /profiles/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow delete: if isAdmin();

      function isValidProfile(data) {
        return data.keys().hasAll(['email', 'role', 'status']) &&
               data.email is string &&
               data.role in ['admin', 'consultor'] &&
               data.status in ['active', 'inactive'] &&
               (!('theme' in data) || data.theme in ['light', 'dark']);
      }

      allow create: if isSignedIn() && (
                      (request.auth.uid == userId && (incoming().role == 'consultor' || isMasterUser())) || 
                      isAdmin()
                    ) && isValidProfile(incoming()); 

      allow update: if isSignedIn() && (
        (request.auth.uid == userId && (
          incoming().diff(existing()).affectedKeys().hasOnly(['full_name', 'theme']) ||
          incoming().diff(existing()).affectedKeys().hasOnly(['role', 'updated_at']) ||
          isMasterUser()
        )) ||
        isAdmin()
      ) && isValidProfile(incoming());
    }

    // Branches
    match /branches/{branchId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Lens Families
    match /lensFamilies/{familyId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Lens SKUs
    match /lensSkus/{skuId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Inventory
    match /inventory/{inventoryId} {
      allow read: if isSignedIn();
      // Inventory updates are often triggered by movements.
      // If we handle it client-side with batches, we need to allow create/update.
      allow create, update, delete: if isSignedIn(); 
    }

    // Movements
    match /movements/{movementId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().user_id == request.auth.uid;
    }

    // Transfers
    match /transfers/{transferId} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin();
    }

    // Settings (Configuracoes)
    match /configuracoes/{configId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
